---
import { siteConfig } from '../data/config';

interface Props {
  songs: typeof siteConfig.piosenki;
}

const { songs } = Astro.props;
---

<div id="audio-controller" data-songs={JSON.stringify(songs)} style="display: none;">
  <audio id="player-audio" preload="auto"></audio>
</div>

<script>
  interface Song {
    tytul: string;
    artysta: string;
    src: string;
    cover: string;
  }
  
  const container = document.getElementById('audio-controller') as HTMLElement;
  const audio = document.getElementById('player-audio') as HTMLAudioElement;
  
  if (container && audio) {
    const songsData = JSON.parse(container.getAttribute('data-songs') || '[]') as Song[];
    let currentSlide = -1;
    let unlocked = false;
    
    // Get active slide index based on scroll position
    function getCurrentSlideIndex(): number {
      const slides = document.querySelectorAll('[data-slide]');
      for (let i = 0; i < slides.length; i++) {
        const rect = slides[i].getBoundingClientRect();
        // Check if the slide is occupying the viewport
        if (rect.top >= -window.innerHeight / 2 && rect.top < window.innerHeight / 2) {
          return i;
        }
      }
      return 0;
    }
    
    // Load and play song for a specific slide
    function loadAndPlaySong(slideIndex: number) {
      if (slideIndex === currentSlide) return;
      
      const song = songsData[slideIndex];
      currentSlide = slideIndex;
      
      if (!song || !song.src) {
        audio.pause();
        audio.src = '';
        audio.removeAttribute('data-current-src');
        return;
      }
      
      // Load the new song
      audio.src = song.src;
      audio.setAttribute('data-current-src', song.src);
      audio.load();
      
      // Try to play if audio is unlocked
      if (unlocked) {
        audio.play().catch((err) => {
          console.warn("Autoplay blocked or interrupted:", err);
        });
      }
    }
    
    function addUnlockListeners() {
      document.addEventListener('click', unlockAndPlay);
      document.addEventListener('touchstart', unlockAndPlay);
      document.addEventListener('keydown', unlockAndPlay);
      document.addEventListener('pointerdown', unlockAndPlay);
      document.addEventListener('wheel', unlockAndPlay);
    }
    
    function removeUnlockListeners() {
      document.removeEventListener('click', unlockAndPlay);
      document.removeEventListener('touchstart', unlockAndPlay);
      document.removeEventListener('keydown', unlockAndPlay);
      document.removeEventListener('pointerdown', unlockAndPlay);
      document.removeEventListener('wheel', unlockAndPlay);
    }

    // Unlock audio context on first user interaction
    function unlockAndPlay() {
      if (unlocked) return;
      unlocked = true;
      
      removeUnlockListeners();
      
      // Play the song for the current slide
      const activeSlide = getCurrentSlideIndex();
      const song = songsData[activeSlide];
      
      if (song && song.src) {
        if (currentSlide === activeSlide) {
          audio.play().catch((err) => {
            console.warn("Play failed after interaction unlock:", err);
          });
        } else {
          loadAndPlaySong(activeSlide);
        }
      } else {
        // If the current slide has no song (like Slide 0 PreIntro),
        // we play a brief silent audio to unlock the player.
        // Once the player is unlocked, subsequent programmatic play() calls (e.g. on scroll) will succeed.
        audio.src = "data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA";
        audio.play().then(() => {
          audio.pause();
          audio.src = '';
        }).catch((err) => {
          console.warn("Silent audio unlock failed:", err);
          // If silent play failed, mark as locked so we can try again on the next interaction
          unlocked = false;
          addUnlockListeners();
        });
      }
    }
    
    // Listeners to unlock audio on first interaction
    addUnlockListeners();
    
    // Scroll detection for slide change (using capture to catch scroll events from the .slides container)
    let scrollTimeout: number;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(() => {
        const activeSlide = getCurrentSlideIndex();
        loadAndPlaySong(activeSlide);
      }, 100);
    }, { passive: true, capture: true });

    // Listen for button-triggered slide transitions to play target song instantly
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // 1. "Otwórz niespodziankę" button (Slide 0 -> Slide 1)
      if (target.closest('[data-open-intro]')) {
        unlocked = true;
        loadAndPlaySong(1);
        return;
      }
      
      // 2. "Uruchom podsumowanie" button (Slide 1 -> Slide 2)
      if (target.closest('[data-go-next]')) {
        unlocked = true;
        loadAndPlaySong(2);
        return;
      }
      
      // 3. Side navigation dots (data-target="slide-X")
      const navButton = target.closest('[data-target]');
      if (navButton) {
        const targetId = navButton.getAttribute('data-target');
        if (targetId && targetId.startsWith('slide-')) {
          const slideIndex = parseInt(targetId.replace('slide-', ''), 10);
          if (!isNaN(slideIndex)) {
            unlocked = true;
            loadAndPlaySong(slideIndex);
          }
        }
      }
    });
    
    // When a song ends, loop it by default
    audio.addEventListener('ended', () => {
      audio.currentTime = 0;
      audio.play().catch(() => {});
    });
    
    // Initial setup: load the song for the starting slide
    const initialSlide = getCurrentSlideIndex();
    loadAndPlaySong(initialSlide);
  }
</script>
