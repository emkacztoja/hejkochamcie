---
import { siteConfig } from '../data/config';

interface Props {
  songs: typeof siteConfig.piosenki;
}

const { songs } = Astro.props;
---

<!-- Premium Fullscreen Preloader -->
<div id="preloader" class="preloader-overlay">
  <div class="preloader-content">
    <div class="preloader-heart">❤️</div>
    <p class="preloader-text">Przygotowuję wspomnienia...</p>
    <div class="progress-bar-container">
      <div id="preloader-progress-bar" class="progress-bar-fill"></div>
    </div>
    <div id="preloader-percentage" class="preloader-percentage">0%</div>
  </div>
</div>

<div id="audio-controller" style="display: none;">
  {songs.map((song, index) => (
    song.src ? (
      <audio id={`player-audio-${index}`} src={song.src} preload="auto" loop></audio>
    ) : null
  ))}
</div>

<style>
  .preloader-overlay {
    position: fixed;
    inset: 0;
    background: #07050f;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.8s;
  }
  
  .preloader-overlay.fade-out {
    opacity: 0;
    visibility: hidden;
  }
  
  .preloader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 280px;
    text-align: center;
  }
  
  .preloader-heart {
    font-size: 3.5rem;
    margin-bottom: 24px;
    filter: drop-shadow(0 0 15px rgba(255, 77, 141, 0.6));
    animation: heart-pulse-loading 1.2s ease-in-out infinite;
  }
  
  .preloader-text {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
    margin-bottom: 16px;
    letter-spacing: 0.05em;
  }
  
  .progress-bar-container {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .progress-bar-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, #ff4d8d, #7c3aed);
    border-radius: 3px;
    transition: width 0.1s ease-out;
  }
  
  .preloader-percentage {
    font-size: 0.85rem;
    color: #ff4d8d;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  @keyframes heart-pulse-loading {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
</style>

<script>
  const container = document.getElementById('audio-controller') as HTMLElement;
  
  if (container) {
    let currentSlide = -1;
    let currentAudio: HTMLAudioElement | null = null;
    let unlocked = false;
    
    // Get active slide index based on scroll position
    function getCurrentSlideIndex(): number {
      const slides = document.querySelectorAll('[data-slide]');
      for (let i = 0; i < slides.length; i++) {
        const rect = slides[i].getBoundingClientRect();
        if (rect.top >= -window.innerHeight / 2 && rect.top < window.innerHeight / 2) {
          return i;
        }
      }
      return 0;
    }
    
    function getAudioElement(index: number): HTMLAudioElement | null {
      return document.getElementById(`player-audio-${index}`) as HTMLAudioElement | null;
    }
    
    // Play song for a specific slide
    function loadAndPlaySong(slideIndex: number) {
      if (slideIndex === currentSlide) return;
      
      currentSlide = slideIndex;
      
      // Pause previously active audio
      if (currentAudio) {
        currentAudio.pause();
      }
      
      const nextAudio = getAudioElement(slideIndex);
      currentAudio = nextAudio;
      
      if (!nextAudio) return;
      
      // Try to play if audio is unlocked
      if (unlocked) {
        nextAudio.currentTime = 0;
        nextAudio.play().catch((err) => {
          console.warn("Playback failed:", err);
        });
      }
    }
    
    function addUnlockListeners() {
      document.addEventListener('click', unlockAndPlay);
      document.addEventListener('touchstart', unlockAndPlay);
      document.addEventListener('keydown', unlockAndPlay);
      document.addEventListener('pointerdown', unlockAndPlay);
      document.addEventListener('wheel', unlockAndPlay);
    }
    
    function removeUnlockListeners() {
      document.removeEventListener('click', unlockAndPlay);
      document.removeEventListener('touchstart', unlockAndPlay);
      document.removeEventListener('keydown', unlockAndPlay);
      document.removeEventListener('pointerdown', unlockAndPlay);
      document.removeEventListener('wheel', unlockAndPlay);
    }

    // Unlock audio context on first user interaction
    function unlockAndPlay(e?: Event) {
      // Prevent unlocking while preloader is active to avoid race conditions
      if (document.getElementById('preloader')) return;
      
      if (unlocked) return;
      unlocked = true;
      
      removeUnlockListeners();
      
      let activeSlide = getCurrentSlideIndex();
      
      // If the interaction was a click on a navigation button, determine the target slide
      if (e && e.target) {
        const target = e.target as HTMLElement;
        if (target.closest('[data-open-intro]')) {
          activeSlide = 1;
        } else if (target.closest('[data-go-next]')) {
          activeSlide = 2;
        } else {
          const navButton = target.closest('[data-target]');
          if (navButton) {
            const targetId = navButton.getAttribute('data-target');
            if (targetId && targetId.startsWith('slide-')) {
              const slideIndex = parseInt(targetId.replace('slide-', ''), 10);
              if (!isNaN(slideIndex)) {
                activeSlide = slideIndex;
              }
            }
          }
        }
      }
      
      const audios = document.querySelectorAll('#audio-controller audio') as NodeListOf<HTMLAudioElement>;
      
      // Unlock all audios simultaneously using muted=true
      audios.forEach((audioEl) => {
        if (!audioEl.src) return;
        
        const isTarget = audioEl.id === `player-audio-${activeSlide}`;
        
        if (isTarget) {
          // If this is the active slide, play it for real (not muted)
          audioEl.muted = false;
          audioEl.play().catch((err) => {
            console.warn("Active slide play failed:", err);
          });
        } else {
          // Otherwise, silently play and pause to unlock (using muted=true which is fully supported on iOS)
          audioEl.muted = true;
          audioEl.play().then(() => {
            audioEl.pause();
            audioEl.muted = false;
            audioEl.currentTime = 0;
          }).catch((err) => {
            console.warn("Silent play failed for:", audioEl.id, err);
          });
        }
      });
      
      currentSlide = activeSlide;
      currentAudio = getAudioElement(activeSlide);
    }
    
    // ── Smooth Timer-based Loading Animation ─────────────────────────────
    const preloaderEl = document.getElementById('preloader') as HTMLElement;
    const progressBar = document.getElementById('preloader-progress-bar') as HTMLElement;
    const percentageText = document.getElementById('preloader-percentage') as HTMLElement;
    const statusText = document.querySelector('.preloader-text') as HTMLElement;
    
    // Call .load() on all audios to trigger native browser preloading
    const audioElements = document.querySelectorAll('#audio-controller audio') as NodeListOf<HTMLAudioElement>;
    audioElements.forEach((el) => {
      el.load();
    });

    const duration = 2200; // 2.2 seconds loading animation
    const startTime = performance.now();

    function animatePreloader(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min((elapsed / duration) * 100, 100);
      
      if (progressBar) progressBar.style.width = `${progress}%`;
      if (percentageText) percentageText.textContent = `${Math.round(progress)}%`;
      
      if (statusText) {
        if (progress < 30) {
          statusText.textContent = 'Przygotowuję wspomnienia...';
        } else if (progress < 60) {
          statusText.textContent = 'Wczytuję ścieżkę dźwiękową...';
        } else if (progress < 90) {
          statusText.textContent = 'Dekoruję slajdy...';
        } else {
          statusText.textContent = 'Gotowe!';
        }
      }

      if (progress < 100) {
        requestAnimationFrame(animatePreloader);
      } else {
        setTimeout(() => {
          if (preloaderEl) {
            preloaderEl.classList.add('fade-out');
            setTimeout(() => {
              preloaderEl.remove();
            }, 800);
          }
        }, 200);
      }
    }
    
    requestAnimationFrame(animatePreloader);
    
    // Listeners to unlock audio on first interaction
    addUnlockListeners();
    
    // Scroll detection for slide change
    let scrollTimeout: number;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(() => {
        const activeSlide = getCurrentSlideIndex();
        loadAndPlaySong(activeSlide);
      }, 100);
    }, { passive: true, capture: true });

    // Listen for button-triggered slide transitions to play target song instantly
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // 1. "Otwórz" button (Slide 0 -> Slide 1)
      if (target.closest('[data-open-intro]')) {
        unlocked = true;
        loadAndPlaySong(1);
        return;
      }
      
      // 2. "Uruchom podsumowanie" button (Slide 1 -> Slide 2)
      if (target.closest('[data-go-next]')) {
        unlocked = true;
        loadAndPlaySong(2);
        return;
      }
      
      // 3. Side navigation dots (data-target="slide-X")
      const navButton = target.closest('[data-target]');
      if (navButton) {
        const targetId = navButton.getAttribute('data-target');
        if (targetId && targetId.startsWith('slide-')) {
          const slideIndex = parseInt(targetId.replace('slide-', ''), 10);
          if (!isNaN(slideIndex)) {
            unlocked = true;
            loadAndPlaySong(slideIndex);
          }
        }
      }
    });
  }
</script>
