---
import { siteConfig } from '../data/config';

interface Props {
  songs: typeof siteConfig.piosenki;
}

const { songs } = Astro.props;
---

<div id="audio-controller" style="display: none;">
  {songs.map((song, index) => (
    song.src ? (
      <audio id={`player-audio-${index}`} src={song.src} preload="auto" loop></audio>
    ) : null
  ))}
</div>

<script>
  const container = document.getElementById('audio-controller') as HTMLElement;
  
  if (container) {
    let currentSlide = -1;
    let currentAudio: HTMLAudioElement | null = null;
    let unlocked = false;
    
    // Get active slide index based on scroll position
    function getCurrentSlideIndex(): number {
      const slides = document.querySelectorAll('[data-slide]');
      for (let i = 0; i < slides.length; i++) {
        const rect = slides[i].getBoundingClientRect();
        if (rect.top >= -window.innerHeight / 2 && rect.top < window.innerHeight / 2) {
          return i;
        }
      }
      return 0;
    }
    
    function getAudioElement(index: number): HTMLAudioElement | null {
      return document.getElementById(`player-audio-${index}`) as HTMLAudioElement | null;
    }
    
    // Play song for a specific slide
    function loadAndPlaySong(slideIndex: number) {
      if (slideIndex === currentSlide) return;
      
      currentSlide = slideIndex;
      
      // Pause previously active audio
      if (currentAudio) {
        currentAudio.pause();
      }
      
      const nextAudio = getAudioElement(slideIndex);
      currentAudio = nextAudio;
      
      if (!nextAudio) return;
      
      // Try to play if audio is unlocked
      if (unlocked) {
        nextAudio.currentTime = 0;
        nextAudio.play().catch((err) => {
          console.warn("Playback failed:", err);
        });
      }
    }
    
    function addUnlockListeners() {
      document.addEventListener('click', unlockAndPlay);
      document.addEventListener('touchstart', unlockAndPlay);
      document.addEventListener('keydown', unlockAndPlay);
      document.addEventListener('pointerdown', unlockAndPlay);
      document.addEventListener('wheel', unlockAndPlay);
    }
    
    function removeUnlockListeners() {
      document.removeEventListener('click', unlockAndPlay);
      document.removeEventListener('touchstart', unlockAndPlay);
      document.removeEventListener('keydown', unlockAndPlay);
      document.removeEventListener('pointerdown', unlockAndPlay);
      document.removeEventListener('wheel', unlockAndPlay);
    }

    // Unlock audio context on first user interaction
    function unlockAndPlay() {
      if (unlocked) return;
      unlocked = true;
      
      removeUnlockListeners();
      
      const activeSlide = getCurrentSlideIndex();
      const audios = document.querySelectorAll('#audio-controller audio') as NodeListOf<HTMLAudioElement>;
      
      // Unlock all audios simultaneously
      audios.forEach((audioEl) => {
        if (!audioEl.src) return;
        
        const isTarget = audioEl.id === `player-audio-${activeSlide}`;
        
        if (isTarget) {
          // If this is the active slide, play it for real (not muted)
          audioEl.muted = false;
          audioEl.play().catch((err) => {
            console.warn("Active slide play failed:", err);
          });
        } else {
          // Otherwise, silently play and pause to unlock (using muted=true which is fully supported on iOS)
          audioEl.muted = true;
          audioEl.play().then(() => {
            audioEl.pause();
            audioEl.muted = false;
            audioEl.currentTime = 0;
          }).catch((err) => {
            console.warn("Silent play failed for:", audioEl.id, err);
          });
        }
      });
      
      currentSlide = activeSlide;
      currentAudio = getAudioElement(activeSlide);
    }
    
    // Listeners to unlock audio on first interaction
    addUnlockListeners();
    
    // Scroll detection for slide change
    let scrollTimeout: number;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = window.setTimeout(() => {
        const activeSlide = getCurrentSlideIndex();
        loadAndPlaySong(activeSlide);
      }, 100);
    }, { passive: true, capture: true });

    // Listen for button-triggered slide transitions to play target song instantly
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // 1. "Otwórz" button (Slide 0 -> Slide 1)
      if (target.closest('[data-open-intro]')) {
        unlocked = true;
        loadAndPlaySong(1);
        return;
      }
      
      // 2. "Uruchom podsumowanie" button (Slide 1 -> Slide 2)
      if (target.closest('[data-go-next]')) {
        unlocked = true;
        loadAndPlaySong(2);
        return;
      }
      
      // 3. Side navigation dots (data-target="slide-X")
      const navButton = target.closest('[data-target]');
      if (navButton) {
        const targetId = navButton.getAttribute('data-target');
        if (targetId && targetId.startsWith('slide-')) {
          const slideIndex = parseInt(targetId.replace('slide-', ''), 10);
          if (!isNaN(slideIndex)) {
            unlocked = true;
            loadAndPlaySong(slideIndex);
          }
        }
      }
    });
  }
</script>
