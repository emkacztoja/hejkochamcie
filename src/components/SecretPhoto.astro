---
import { siteConfig } from '../data/config';
import SlideShell from './SlideShell.astro';

const sekret = siteConfig.sekretneZdjecie;
---

<SlideShell id="slide-9" bg="warm" showScrollHint={true}>
  <p class="slide-eyebrow">Slajd 9 z 11</p>
  <h2 class="slide-title">
    Jedno <span class="gradient">szczególne</span> zdjęcie 📸
  </h2>
  <p class="slide-subtitle">Przytrzymaj, aby zobaczyć</p>
  
  <div class="secret-photo-wrapper">
    <div class="secret-photo" data-secret-photo>
      <div class="secret-cover">
        <span class="secret-icon">💕</span>
        <span class="secret-hint">Przytrzymaj, aby zobaczyć</span>
      </div>
      {sekret.src ? (
        <img src={sekret.src} alt={sekret.podpis || 'Sekretne zdjęcie'} class="secret-image" />
      ) : (
        <div class="secret-placeholder">
          <span class="secret-placeholder-icon">📷</span>
          <p>Dodaj zdjęcie do</p>
          <code>{sekret.src || '/images/first-photo.jpg'}</code>
        </div>
      )}
    </div>
    
    {sekret.podpis && (
      <p class="secret-caption">{sekret.podpis}</p>
    )}
  </div>
</SlideShell>

<style>
  .secret-photo-wrapper {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  
  .secret-photo {
    position: relative;
    width: 320px;
    height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    cursor: pointer;
  }
  
  .secret-cover {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-pink), var(--accent-purple));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 2;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  
  .secret-photo:hover .secret-cover,
  .secret-photo:active .secret-cover {
    opacity: 0;
    transform: scale(1.1);
  }
  
  .secret-icon {
    font-size: 4rem;
  }
  
  .secret-hint {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    text-align: center;
    padding: 0 20px;
  }
  
  .secret-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .secret-placeholder {
    width: 100%;
    height: 100%;
    background: var(--bg-elevated);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: center;
    padding: 20px;
    border: 2px dashed rgba(255, 77, 141, 0.3);
  }
  
  .secret-placeholder-icon {
    font-size: 3rem;
  }
  
  .secret-placeholder p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  
  .secret-placeholder code {
    background: rgba(255, 255, 255, 0.1);
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--accent-pink);
  }
  
  .secret-caption {
    font-family: var(--font-hand);
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }
  
  @media (max-width: 480px) {
    .secret-photo {
      width: 280px;
      height: 350px;
    }
  }
</style>

<script>
  const photo = document.querySelector('[data-secret-photo]') as HTMLElement;
  
  // For mobile: show on long press instead of hover
  let pressTimer: number;
  
  photo?.addEventListener('mousedown', () => {
    pressTimer = window.setTimeout(() => {
      const cover = photo.querySelector('.secret-cover') as HTMLElement;
      if (cover) {
        cover.style.opacity = '0';
        cover.style.transform = 'scale(1.1)';
      }
    }, 300);
  });
  
  photo?.addEventListener('mouseup', () => {
    clearTimeout(pressTimer);
    const cover = photo.querySelector('.secret-cover') as HTMLElement;
    if (cover) {
      cover.style.opacity = '';
      cover.style.transform = '';
    }
  });
  
  photo?.addEventListener('mouseleave', () => {
    clearTimeout(pressTimer);
  });
</script>
