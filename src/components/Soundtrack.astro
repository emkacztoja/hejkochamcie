---
import { siteConfig } from '../data/config';
import SlideShell from './SlideShell.astro';
---

<SlideShell id="slide-4" bg="warm" showScrollHint={true}>
  <p class="slide-eyebrow">Slajd 4 z 9</p>
  <h2 class="slide-title">
    Muzyczne tło <span class="gradient">tamtych dni</span> 🎧
  </h2>
  <p class="slide-subtitle">{siteConfig.soundtrackOpis}</p>

  <div class="spotify-card">
    <iframe
      data-spotify
      title="Nasz utwór na Spotify"
      src={siteConfig.spotifyEmbedUrl}
      width="100%"
      height="352"
      frameborder="0"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
    ></iframe>
  </div>


</SlideShell>

<script>
  // Jeśli iframe Spotify nie załaduje się w 4s — pokaż fallback
  const iframe = document.querySelector<HTMLIFrameElement>('[data-spotify]');
  if (iframe) {
    const fallback = document.createElement('div');
    fallback.className = 'spotify-fallback';
    fallback.innerHTML =
      'Nie udało się załadować odtwarzacza Spotify.<br/>Sprawdź, czy link w <code>spotifyEmbedUrl</code> jest poprawny.';
    iframe.after(fallback);
    fallback.style.display = 'none';

    let loaded = false;
    iframe.addEventListener('load', () => {
      loaded = true;
      fallback.style.display = 'none';
    });

    setTimeout(() => {
      if (!loaded) fallback.style.display = 'block';
    }, 4000);
  }
</script>