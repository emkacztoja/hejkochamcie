---
import { siteConfig } from '../data/config';
import SlideShell from './SlideShell.astro';

const listy = siteConfig.listy;
---

<SlideShell id="slide-8" bg="purple" showScrollHint={true}>
  <p class="slide-eyebrow">Slajd 8 z 11</p>
  <h2 class="slide-title">
    Otwórz, gdy… <span class="gradient">potrzebujesz</span> 💌
  </h2>
  <p class="slide-subtitle">Kliknij w kopertę, gdy będziesz potrzebować słów otuchy.</p>
  
  <div class="letters-grid">
    {listy.map((list, i) => (
      <button class="letter-card" data-letter-index={i} type="button">
        <div class="letter-envelope">
          <svg class="envelope-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <span class="letter-label">{list.okazja}</span>
        <span class="letter-hint">Kliknij, aby otworzyć</span>
      </button>
    ))}
  </div>
  
  <!-- Modal for letter content -->
  <div class="letter-modal" id="letter-modal" aria-hidden="true">
    <div class="letter-modal-backdrop"></div>
    <div class="letter-modal-content">
      <button class="letter-modal-close" id="letter-modal-close" type="button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <div class="letter-paper">
        <span class="letter-paper-icon">💕</span>
        <p class="letter-paper-text" id="letter-text"></p>
        <span class="letter-paper-signature">— zawsze Twój 💗</span>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .letters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }
  
  .letter-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    text-align: center;
    cursor: pointer;
  }
  
  .letter-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--accent-pink);
    transform: translateY(-4px);
  }
  
  .letter-envelope {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--accent-pink), var(--accent-purple));
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }
  
  .letter-card:hover .letter-envelope {
    transform: scale(1.1) rotate(-5deg);
  }
  
  .envelope-icon {
    color: white;
  }
  
  .letter-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
  }
  
  .letter-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  
  /* Modal */
  .letter-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  
  .letter-modal.open {
    opacity: 1;
    visibility: visible;
  }
  
  .letter-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
  }
  
  .letter-modal-content {
    position: relative;
    max-width: 500px;
    width: 100%;
    transform: scale(0.9) translateY(20px);
    transition: transform 0.3s ease;
  }
  
  .letter-modal.open .letter-modal-content {
    transform: scale(1) translateY(0);
  }
  
  .letter-modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: background 0.2s ease;
  }
  
  .letter-modal-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  
  .letter-paper {
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    border-radius: var(--radius-lg);
    padding: 40px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
    text-align: center;
  }
  
  .letter-paper-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 20px;
  }
  
  .letter-paper-text {
    font-family: var(--font-hand);
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    line-height: 1.6;
    color: #451a03;
    margin: 0 0 24px;
  }
  
  .letter-paper-signature {
    font-family: var(--font-hand);
    font-size: 1.1rem;
    color: #92400e;
  }
</style>

<script>
  const letters = document.querySelectorAll('[data-letter-index]');
  const modal = document.getElementById('letter-modal')!;
  const modalText = document.getElementById('letter-text')!;
  const modalClose = document.getElementById('letter-modal-close')!;
  const backdrop = modal.querySelector('.letter-modal-backdrop')!;
  
  const listyData = listy.map(l => l.tresc);
  
  function openLetter(index: number) {
    modalText.textContent = listyData[index] || '';
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  
  function closeLetter() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }
  
  letters.forEach((letter) => {
    letter.addEventListener('click', () => {
      const index = letter.getAttribute('data-letter-index');
      if (index !== null) {
        openLetter(parseInt(index));
        
        // Confetti
        import('canvas-confetti').then(({ default: confetti }) => {
          confetti({
            particleCount: 80,
            spread: 70,
            origin: { x: 0.5, y: 0.6 },
            colors: ['#ff4d8d', '#ffd166', '#ff6b6b'],
          });
        });
      }
    });
  });
  
  modalClose.addEventListener('click', closeLetter);
  backdrop.addEventListener('click', closeLetter);
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLetter();
  });
</script>
